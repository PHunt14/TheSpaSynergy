# ── Square ─────────────────────────────────────────────────────
SQUARE_APPLICATION_ID=YOUR_APP_ID
SQUARE_APPLICATION_SECRET=YOUR_OAUTH_SECRET
SQUARE_ACCESS_TOKEN=YOUR_PLATFORM_ACCESS_TOKEN
SQUARE_WEBHOOK_SIGNATURE_KEY=YOUR_WEBHOOK_SIGNATURE_KEY
SQUARE_ENVIRONMENT=sandbox

# ── DynamoDB ───────────────────────────────────────────────────
# Table name prefix from Amplify (e.g. "Vendor-abc123-NONE")
# Run: aws dynamodb list-tables --query "TableNames" to find yours
DYNAMO_TABLE_VENDOR=Vendor-XXXXX-NONE
DYNAMO_TABLE_STAFF=StaffSchedule-XXXXX-NONE
DYNAMO_TABLE_APPOINTMENT=Appointment-XXXXX-NONE
AWS_REGION=us-east-1

# ── Service ────────────────────────────────────────────────────
PORT=3001
APP_URL=http://localhost:3000
# Comma-separated origins allowed for CORS
CORS_ORIGINS=http://localhost:3000
