{
  "name": "TheSpaSynergy",
  "version": "1.0.0",
  "type": "module",
  "description": "This is now a demo project at this time.",
  "main": "index.js",
  "scripts": {
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:unit": "node --experimental-vm-modules node_modules/jest/bin/jest.js --selectProjects unit",
    "test:components": "node --experimental-vm-modules node_modules/jest/bin/jest.js --selectProjects components",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "test:e2e": "npx playwright test",
    "test:e2e:headed": "npx playwright test --headed",
    "dev": "next dev",
    "dev:full": "concurrently \"npx ampx sandbox\" \"next dev\"",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "sandbox": "npx ampx sandbox",
    "sandbox:delete": "npx ampx sandbox delete",
    "seed": "node scripts/seed-amplify.js",
    "seed:clear": "node scripts/clear-data.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PHunt14/TheSpaSynergy.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/PHunt14/TheSpaSynergy/issues"
  },
  "homepage": "https://github.com/PHunt14/TheSpaSynergy#readme",
  "dependencies": {
    "@aws-amplify/adapter-nextjs": "^1.7.2",
    "@aws-amplify/ui-react": "^6.15.0",
    "@aws-sdk/client-cognito-identity-provider": "^3.995.0",
    "@aws-sdk/client-dynamodb": "^3.0.0",
    "@aws-sdk/client-secrets-manager": "^3.0.0",
    "@aws-sdk/client-ses": "^3.0.0",
    "@aws-sdk/client-sns": "^3.1000.0",
    "@aws-sdk/lib-dynamodb": "^3.0.0",
    "aws-amplify": "^6.0.0",
    "next": "^16.2.2",
    "react": "^19.2.3",
    "react-calendar": "^6.0.0",
    "react-date-picker": "^12.0.1",
    "react-datepicker": "^9.1.0",
    "react-dom": "^19.2.3",
    "square": "^39.0.0"
  },
  "devDependencies": {
    "@aws-amplify/backend": "^1.0.0",
    "@aws-amplify/backend-cli": "^1.0.0",
    "@jest/globals": "^30.3.0",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "19.2.14",
    "aws-cdk": "^2.0.0",
    "aws-cdk-lib": "^2.0.0",
    "concurrently": "^9.2.1",
    "constructs": "^10.0.0",
    "esbuild": "^0.19.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.3.0",
    "ts-jest": "^29.4.6",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
